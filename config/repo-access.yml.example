# repo-access.yml — Role-group repo access config for hermes-worktree
#
# Place this file at /data/agent-stack/repo-access.yml inside the running
# container. The data volume is already persistent — no external mount needed.
#
# One-time setup (run once after first deploy):
#   docker cp repo-access.yml <hermes-container>:/data/agent-stack/repo-access.yml
#
# On every container start, the hermes-repos startup hook reads this file and:
#   1. Clones any missing bare repos into /opt/repos/bare/
#   2. Writes REPOS= into each profile's .env
#
# Access levels:
#   rw  → written to REPOS= (hermes-worktree add allowed for this profile+repo)
#   ro  → not written (profile can read bare clone but cannot create worktrees)
# Omitted groups → no access for that profile/group pair.

# GitHub source for bare repo cloning.
# All repos in repo_groups are cloned from: https://github.com/<org>/<repo>
# Override per-repo with the full "OtherOrg/repo-name" syntax.
github:
  org: my-github-org

# Repo groups — stable collections of related repos.
# Add a repo here when onboarding it; group membership rarely changes.
repo_groups:
  platform:
    - my-platform-repo
    - my-config-repo

  apps:
    - my-app-repo
    - my-api-repo

  storefronts:
    - my-store-repo

  tools:
    - my-tooling-repo

# Profile access map.
# Each profile gets REPOS= set to the union of all rw groups.
profiles:
  my-org-cto:
    - group: platform
      level: rw
    - group: apps
      level: ro
    - group: storefronts
      level: ro
    - group: tools
      level: ro

  my-org-backend:
    - group: platform
      level: ro
    - group: apps
      level: rw
    - group: tools
      level: ro

  my-org-frontend:
    - group: apps
      level: rw
    - group: storefronts
      level: rw
    - group: tools
      level: ro

  my-org-qa:
    - group: platform
      level: ro
    - group: apps
      level: ro
    - group: storefronts
      level: ro
    - group: tools
      level: ro

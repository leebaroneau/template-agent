COMPOSE_PROJECT_NAME=template-agent
TEMPLATE_AGENT_IMAGE=template-agent:local
PAPERCLIP_PORT=3100
PAPERCLIP_PUBLIC_URL=http://localhost:3100
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip,localhost,127.0.0.1
PAPERCLIP_HOSTNAME=paperclip.example.com
HERMES_HOSTNAME=hermes.example.com
HERMES_PORT=9119
HERMES_DASHBOARD_ENABLED=0
HERMES_DASHBOARD_TUI=1
HERMES_DASHBOARD_SKIP_BUILD=1
HERMES_PROFILES=default
HERMES_GATEWAY_AUTOSTART=1
HERMES_GATEWAY_PROFILES=auto
PROFILE_SYNC_ENABLED=1
PROFILE_SYNC_INTERVAL_SEC=60
PROFILE_SYNC_DELETE_MODE=archive
PROFILE_SYNC_GRANT_MANAGER_ASSIGN_TASKS=1
PROFILE_SYNC_DEFAULT_COMPANY_SKILLS=gbrain,use-100m-framework
PROFILE_SYNC_DEFAULT_COMPANY_SKILL_SOURCE_DIR=/opt/hermes-runtime/skills
PROFILE_SYNC_API_BASE=http://127.0.0.1:3100
PAPERCLIP_AGENT_API_URL=http://127.0.0.1:3100
PAPERCLIP_PROFILE_SYNC_API_KEY=
PAPERCLIP_COMPANY_IDS=
PAPERCLIP_COMPANIES=
# Paperclip MCP server (Hermes -> Paperclip issue creation).
# Leave PAPERCLIP_API_KEY blank to reuse PAPERCLIP_PROFILE_SYNC_API_KEY above.
PAPERCLIP_API_KEY=
# Required before the Paperclip MCP plugin will work from inside Hermes.
# Set to the company UUID once you have it (e.g. via `paperclipai agent list -C <id>`
# or the dashboard). Empty here means MCP tool calls error with "companyId is required".
PAPERCLIP_DEFAULT_COMPANY_ID=
ORG_MIRROR_ROOT=/data/agent-stack
PAPERCLIP_VERSION=2026.513.0
HERMES_AGENT_REF=main
GBRAIN_REF=master
PAPERCLIP_TELEMETRY_DISABLED=1
